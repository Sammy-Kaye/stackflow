# StackFlow — Environment Variables
#
# Copy this file to .env and fill in the values for your environment.
# The .env file is excluded from git — never commit real secrets.
#
# Format: KEY=value
# All values marked REPLACE_WITH_* must be changed before the stack will work correctly.
# Values without REPLACE_WITH_* are safe defaults for local development.

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
# The name of the PostgreSQL database created on first start
POSTGRES_DB=stackflow

# The PostgreSQL superuser username for the stackflow database
POSTGRES_USER=stackflow

# The PostgreSQL password — change this in any shared or production environment
POSTGRES_PASSWORD=stackflow_dev

# ── API — Database connection string ──────────────────────────────────────────
# Full Npgsql connection string used by EF Core.
# Host must match the Docker Compose service name ("postgres") when running in Docker.
# Format: Host=<host>;Port=<port>;Database=<db>;Username=<user>;Password=<password>
ConnectionStrings__DefaultConnection=Host=postgres;Port=5432;Database=stackflow;Username=stackflow;Password=stackflow_dev

# ── API — JWT (Phase 2 — not used until Feature 2) ────────────────────────────
# Secret key used to sign JWT access tokens.
# Must be at least 32 characters. Use a cryptographically random string in production.
Jwt__Secret=REPLACE_WITH_A_LONG_RANDOM_SECRET_MIN_32_CHARS

# Identifies this API as the token issuer — included in the JWT "iss" claim
Jwt__Issuer=stackflow-api

# Identifies the intended audience for the token — included in the JWT "aud" claim
Jwt__Audience=stackflow-app

# How long (in minutes) an access token is valid before the client must refresh it
Jwt__AccessTokenExpiryMinutes=60

# How long (in days) a refresh token is valid before the user must log in again
Jwt__RefreshTokenExpiryDays=30

# ── API — RabbitMQ ────────────────────────────────────────────────────────────
# Hostname of the RabbitMQ server. Use "rabbitmq" when running in Docker Compose.
RabbitMq__Host=rabbitmq

# AMQP port — 5672 is the default
RabbitMq__Port=5672

# RabbitMQ credentials. "guest" / "guest" is the default for the management image.
# Change these in any shared or production environment.
RabbitMq__Username=guest
RabbitMq__Password=guest

# ── API — Email (MailKit + Brevo SMTP) ────────────────────────────────────────
# SMTP relay host. Default is Brevo (formerly Sendinblue) — free tier, 300 emails/day.
# Swap host and credentials to use a different provider without changing any code.
Email__SmtpHost=smtp-relay.brevo.com

# SMTP submission port (587 with STARTTLS)
Email__SmtpPort=587

# Brevo SMTP username (your Brevo account login email)
Email__Username=REPLACE_WITH_BREVO_SMTP_USERNAME

# Brevo SMTP key (generated in Brevo dashboard under SMTP & API → SMTP)
Email__Password=REPLACE_WITH_BREVO_SMTP_KEY

# The "From" address that appears in outgoing emails
Email__FromAddress=noreply@yourdomain.com

# The "From" display name that appears in outgoing emails
Email__FromName=StackFlow

# ── API — Object Storage (Phase 2 — Cloudflare R2 in prod, local dev leave blank for now)
# S3-compatible object storage. Production: Cloudflare R2. Local dev: MinIO (via Docker Compose).
# The same AWSSDK.S3 code is used for both — only the endpoint and credentials differ.
Storage__ServiceUrl=
Storage__AccessKey=
Storage__SecretKey=
Storage__BucketName=stackflow
Storage__Region=us-east-1

# ── Frontend ──────────────────────────────────────────────────────────────────
# Base URL of the API, used by the Axios client in the frontend.
# When running in Docker Compose, the frontend container talks to the host via this URL.
# For local dev (npm run dev), set this to http://localhost:5000
VITE_API_URL=http://localhost:5000
