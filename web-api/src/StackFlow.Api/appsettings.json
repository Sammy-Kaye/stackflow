{
  // All sensitive values are read from environment variables — no secrets in this file.
  // Set environment variables in your shell, docker-compose.yml, or .env file.
  // See .env.example at the project root for the full list of required variables.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  // Database — PostgreSQL via EF Core / Npgsql
  // Production: set ConnectionStrings__DefaultConnection environment variable
  "ConnectionStrings": {
    "DefaultConnection": ""
  },

  // JWT authentication (Phase 2)
  // Production: set Jwt__Secret to a cryptographically random string of at least 32 characters
  "Jwt": {
    "Secret": "",
    "Issuer": "",
    "Audience": "",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },

  // RabbitMQ message broker
  // Production: set RabbitMq__Host, RabbitMq__Username, RabbitMq__Password environment variables
  "RabbitMq": {
    "Host": "",
    "Port": 5672,
    "Username": "",
    "Password": ""
  },

  // Email via MailKit + SMTP (Brevo as provider — swap by changing SmtpHost/credentials)
  // Production: set Email__* environment variables — never commit real credentials
  "Email": {
    "SmtpHost": "",
    "SmtpPort": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "",
    "FromName": "StackFlow"
  },

  // Object storage — Cloudflare R2 in production, MinIO in local dev (both S3-compatible)
  // Production: set Storage__* environment variables — never commit real credentials
  // Local dev: leave blank — file storage is a Phase 2 concern
  "Storage": {
    "ServiceUrl": "",
    "AccessKey": "",
    "SecretKey": "",
    "BucketName": "stackflow",
    "Region": "us-east-1"
  }
}
